{"number":107,"nameTurkish":"Maûn","nameArabic":"الماعون","revelationType":"Mekke","ayahCount":7,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ","turkishTransliteration":null,"turkishTranslation":"Dini yalan sayanı gördün mü"},{"number":2,"arabicText":"فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ","turkishTransliteration":null,"turkishTranslation":"Öksüzü kakıştıran, yoksulu doyurmaya yanaşmayan kimse işte odur"},{"number":3,"arabicText":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ","turkishTransliteration":null,"turkishTranslation":"Öksüzü kakıştıran, yoksulu doyurmaya yanaşmayan kimse işte odur"},{"number":4,"arabicText":"فَوَيۡلٞ لِّلۡمُصَلِّينَ","turkishTransliteration":null,"turkishTranslation":"Vay o namaz kılanların haline ki"},{"number":5,"arabicText":"ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ","turkishTransliteration":null,"turkishTranslation":"Onlar kıldıkları namazdan gafildirler"},{"number":6,"arabicText":"ٱلَّذِينَ هُمۡ يُرَآءُونَ","turkishTransliteration":null,"turkishTranslation":"Onlar gösteriş yaparlar"},{"number":7,"arabicText":"وَيَمۡنَعُونَ ٱلۡمَاعُونَ","turkishTransliteration":null,"turkishTranslation":"Onlar basit şeyleri dahi vermezler"}]}
