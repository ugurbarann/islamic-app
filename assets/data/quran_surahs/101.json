{"number":101,"nameTurkish":"Kâria","nameArabic":"القارعة","revelationType":"Mekke","ayahCount":11,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"ٱلۡقَارِعَةُ","turkishTransliteration":null,"turkishTranslation":"Gürültü koparacak olan"},{"number":2,"arabicText":"مَا ٱلۡقَارِعَةُ","turkishTransliteration":null,"turkishTranslation":"Nedir o gürültü koparacak olan"},{"number":3,"arabicText":"وَمَآ أَدۡرَىٰكَ مَا ٱلۡقَارِعَةُ","turkishTransliteration":null,"turkishTranslation":"O gürültü koparacak olanın ne olduğunu sen bilir misin"},{"number":4,"arabicText":"يَوۡمَ يَكُونُ ٱلنَّاسُ كَٱلۡفَرَاشِ ٱلۡمَبۡثُوثِ","turkishTransliteration":null,"turkishTranslation":"O gün insanlar, ateş etrafında çırpınıp dökülen pervaneye dönecekler"},{"number":5,"arabicText":"وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ٱلۡمَنفُوشِ","turkishTransliteration":null,"turkishTranslation":"Dağlar, atılmış renkli yüne benzeyecekler"},{"number":6,"arabicText":"فَأَمَّا مَن ثَقُلَتۡ مَوَٰزِينُهُۥ","turkishTransliteration":null,"turkishTranslation":"Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır"},{"number":7,"arabicText":"فَهُوَ فِي عِيشَةٖ رَّاضِيَةٖ","turkishTransliteration":null,"turkishTranslation":"Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır"},{"number":8,"arabicText":"وَأَمَّا مَنۡ خَفَّتۡ مَوَٰزِينُهُۥ","turkishTransliteration":null,"turkishTranslation":"Tartıları hafif gelenler ise"},{"number":9,"arabicText":"فَأُمُّهُۥ هَاوِيَةٞ","turkishTransliteration":null,"turkishTranslation":"Onların yeri bir çukurdur"},{"number":10,"arabicText":"وَمَآ أَدۡرَىٰكَ مَا هِيَهۡ","turkishTransliteration":null,"turkishTranslation":"O çukurun ne olduğunu sen bilir misin"},{"number":11,"arabicText":"نَارٌ حَامِيَةُۢ","turkishTransliteration":null,"turkishTranslation":"O, kızgın bir ateştir"}]}
