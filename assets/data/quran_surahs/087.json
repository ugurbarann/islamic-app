{"number":87,"nameTurkish":"A'lâ","nameArabic":"الأعلى","revelationType":"Mekke","ayahCount":19,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"سَبِّحِ ٱسۡمَ رَبِّكَ ٱلۡأَعۡلَى","turkishTransliteration":null,"turkishTranslation":"Yüce Rabbinin adını tesbih et"},{"number":2,"arabicText":"ٱلَّذِي خَلَقَ فَسَوَّىٰ","turkishTransliteration":null,"turkishTranslation":"O, yaratıp şekil vermiştir"},{"number":3,"arabicText":"وَٱلَّذِي قَدَّرَ فَهَدَىٰ","turkishTransliteration":null,"turkishTranslation":"O, her şeyi ölçüyle yapıp doğru yolu göstermiştir"},{"number":4,"arabicText":"وَٱلَّذِيٓ أَخۡرَجَ ٱلۡمَرۡعَىٰ","turkishTransliteration":null,"turkishTranslation":"O, yeşillikler bitirmiştir"},{"number":5,"arabicText":"فَجَعَلَهُۥ غُثَآءً أَحۡوَىٰ","turkishTransliteration":null,"turkishTranslation":"Sonra da onları siyah çerçöpe çevirmiştir"},{"number":6,"arabicText":"سَنُقۡرِئُكَ فَلَا تَنسَىٰٓ","turkishTransliteration":null,"turkishTranslation":"Sana Kuran'ı Biz okutacağız ve asla unutmayacaksın"},{"number":7,"arabicText":"إِلَّا مَا شَآءَ ٱللَّهُۚ إِنَّهُۥ يَعۡلَمُ ٱلۡجَهۡرَ وَمَا يَخۡفَىٰ","turkishTransliteration":null,"turkishTranslation":"Allah'ın dilediği bundan müstesnadır. Doğrusu açığı da, gizliyi de bilen O'dur"},{"number":8,"arabicText":"وَنُيَسِّرُكَ لِلۡيُسۡرَىٰ","turkishTransliteration":null,"turkishTranslation":"Kolay olanı yapmayı sana kolaylaştırırız"},{"number":9,"arabicText":"فَذَكِّرۡ إِن نَّفَعَتِ ٱلذِّكۡرَىٰ","turkishTransliteration":null,"turkishTranslation":"Faydalı olacaksa insanlara öğüt ver"},{"number":10,"arabicText":"سَيَذَّكَّرُ مَن يَخۡشَىٰ","turkishTransliteration":null,"turkishTranslation":"Allah'tan korkan öğüt alacaktır"},{"number":11,"arabicText":"وَيَتَجَنَّبُهَا ٱلۡأَشۡقَى","turkishTransliteration":null,"turkishTranslation":"Bedbaht olan ondan kaçınacaktır"},{"number":12,"arabicText":"ٱلَّذِي يَصۡلَى ٱلنَّارَ ٱلۡكُبۡرَىٰ","turkishTransliteration":null,"turkishTranslation":"O, en büyük ateşe yaslanacaktır"},{"number":13,"arabicText":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحۡيَىٰ","turkishTransliteration":null,"turkishTranslation":"O, orada ne ölecektir ne de dirilecektir"},{"number":14,"arabicText":"قَدۡ أَفۡلَحَ مَن تَزَكَّىٰ","turkishTransliteration":null,"turkishTranslation":"Arınmış olan, Rabbinin adını anıp namaz kılan, saadete erişecektir"},{"number":15,"arabicText":"وَذَكَرَ ٱسۡمَ رَبِّهِۦ فَصَلَّىٰ","turkishTransliteration":null,"turkishTranslation":"Arınmış olan, Rabbinin adını anıp namaz kılan, saadete erişecektir"},{"number":16,"arabicText":"بَلۡ تُؤۡثِرُونَ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا","turkishTransliteration":null,"turkishTranslation":"Ama sizler dünya hayatını tercih ediyorsunuz"},{"number":17,"arabicText":"وَٱلۡأٓخِرَةُ خَيۡرٞ وَأَبۡقَىٰٓ","turkishTransliteration":null,"turkishTranslation":"Oysa ahiret daha iyi ve daha bakidir"},{"number":18,"arabicText":"إِنَّ هَٰذَا لَفِي ٱلصُّحُفِ ٱلۡأُولَىٰ","turkishTransliteration":null,"turkishTranslation":"Doğrusu bu hükümler ilk sahifelerde, İbrahim ve Musa'nın sahifelerinde de vardır"},{"number":19,"arabicText":"صُحُفِ إِبۡرَٰهِيمَ وَمُوسَىٰ","turkishTransliteration":null,"turkishTranslation":"Doğrusu bu hükümler ilk sahifelerde, İbrahim ve Musa'nın sahifelerinde de vardır"}]}
