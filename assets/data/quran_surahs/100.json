{"number":100,"nameTurkish":"Âdiyât","nameArabic":"العاديات","revelationType":"Mekke","ayahCount":11,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"وَٱلۡعَٰدِيَٰتِ ضَبۡحٗا","turkishTransliteration":null,"turkishTranslation":"And olsun Allah yolunda koştukça koşanlara"},{"number":2,"arabicText":"فَٱلۡمُورِيَٰتِ قَدۡحٗا","turkishTransliteration":null,"turkishTranslation":"And olsun kıvılcımlar saçanlara"},{"number":3,"arabicText":"فَٱلۡمُغِيرَٰتِ صُبۡحٗا","turkishTransliteration":null,"turkishTranslation":"Sabah sabah akına çıkanlara"},{"number":4,"arabicText":"فَأَثَرۡنَ بِهِۦ نَقۡعٗا","turkishTransliteration":null,"turkishTranslation":"Ve tozu dumana katanlara"},{"number":5,"arabicText":"فَوَسَطۡنَ بِهِۦ جَمۡعًا","turkishTransliteration":null,"turkishTranslation":"Düşman topluluğunun içine dalanlara ki"},{"number":6,"arabicText":"إِنَّ ٱلۡإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٞ","turkishTransliteration":null,"turkishTranslation":"İnsan gerçekten Rabbine karşı pek nankördür"},{"number":7,"arabicText":"وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٞ","turkishTransliteration":null,"turkishTranslation":"Doğrusu kendisi de bunların hepsine şahittir"},{"number":8,"arabicText":"وَإِنَّهُۥ لِحُبِّ ٱلۡخَيۡرِ لَشَدِيدٌ","turkishTransliteration":null,"turkishTranslation":"Gerçekten mala da pek düşkündür"},{"number":9,"arabicText":"۞أَفَلَا يَعۡلَمُ إِذَا بُعۡثِرَ مَا فِي ٱلۡقُبُورِ","turkishTransliteration":null,"turkishTranslation":"İnsan, kabirlerde bulunanların çıkarılacağı ve kalblerde olanların ortaya konulacağı bir zamanın geleceğini bilmez mi"},{"number":10,"arabicText":"وَحُصِّلَ مَا فِي ٱلصُّدُورِ","turkishTransliteration":null,"turkishTranslation":"İnsan, kabirlerde bulunanların çıkarılacağı ve kalblerde olanların ortaya konulacağı bir zamanın geleceğini bilmez mi"},{"number":11,"arabicText":"إِنَّ رَبَّهُم بِهِمۡ يَوۡمَئِذٖ لَّخَبِيرُۢ","turkishTransliteration":null,"turkishTranslation":"Doğrusu Rableri o gün onların her şeyinden haberdardır"}]}
