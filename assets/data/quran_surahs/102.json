{"number":102,"nameTurkish":"Tekâsür","nameArabic":"التكاثر","revelationType":"Mekke","ayahCount":8,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"أَلۡهَىٰكُمُ ٱلتَّكَاثُرُ","turkishTransliteration":null,"turkishTranslation":"Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz"},{"number":2,"arabicText":"حَتَّىٰ زُرۡتُمُ ٱلۡمَقَابِرَ","turkishTransliteration":null,"turkishTranslation":"Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz"},{"number":3,"arabicText":"كَلَّا سَوۡفَ تَعۡلَمُونَ","turkishTransliteration":null,"turkishTranslation":"Hayır; öyle olmayın; yakında bileceksiniz"},{"number":4,"arabicText":"ثُمَّ كَلَّا سَوۡفَ تَعۡلَمُونَ","turkishTransliteration":null,"turkishTranslation":"Hayır; gözünüzü açın; yakında bileceksiniz"},{"number":5,"arabicText":"كَلَّا لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡيَقِينِ","turkishTransliteration":null,"turkishTranslation":"Dikkat edin, şayet yaptığınızın sonucunu kesin olarak bir bilseniz"},{"number":6,"arabicText":"لَتَرَوُنَّ ٱلۡجَحِيمَ","turkishTransliteration":null,"turkishTranslation":"And olsun ki, cehennemi göreceksiniz"},{"number":7,"arabicText":"ثُمَّ لَتَرَوُنَّهَا عَيۡنَ ٱلۡيَقِينِ","turkishTransliteration":null,"turkishTranslation":"And olsun ki, onu gözünüzle kesin olarak göreceksiniz"},{"number":8,"arabicText":"ثُمَّ لَتُسۡـَٔلُنَّ يَوۡمَئِذٍ عَنِ ٱلنَّعِيمِ","turkishTransliteration":null,"turkishTranslation":"Sonra o gün, size verilmiş olan her nimetten sorguya çekileceksiniz"}]}
