{"number":109,"nameTurkish":"Kâfirûn","nameArabic":"الكافرون","revelationType":"Mekke","ayahCount":6,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"قُلۡ يَـٰٓأَيُّهَا ٱلۡكَٰفِرُونَ","turkishTransliteration":null,"turkishTranslation":"De ki: \"Ey inkarcılar"},{"number":2,"arabicText":"لَآ أَعۡبُدُ مَا تَعۡبُدُونَ","turkishTransliteration":null,"turkishTranslation":"Ben sizin taptıklarınıza tapmam"},{"number":3,"arabicText":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","turkishTransliteration":null,"turkishTranslation":"Benim taptığıma da sizler tapmazsınız"},{"number":4,"arabicText":"وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ","turkishTransliteration":null,"turkishTranslation":"Ben de sizin taptığınıza tapacak değilim"},{"number":5,"arabicText":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","turkishTransliteration":null,"turkishTranslation":"Benim taptığıma da sizler tapmıyorsunuz"},{"number":6,"arabicText":"لَكُمۡ دِينُكُمۡ وَلِيَ دِينِ","turkishTransliteration":null,"turkishTranslation":"Sizin dininiz size, benim dinim banadır"}]}
