{"number":86,"nameTurkish":"Târık","nameArabic":"الطارق","revelationType":"Mekke","ayahCount":17,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"وَٱلسَّمَآءِ وَٱلطَّارِقِ","turkishTransliteration":null,"turkishTranslation":"Göğe ve Tarık'a and olsun"},{"number":2,"arabicText":"وَمَآ أَدۡرَىٰكَ مَا ٱلطَّارِقُ","turkishTransliteration":null,"turkishTranslation":"Tarık'ın ne olduğunu sen bilir misin"},{"number":3,"arabicText":"ٱلنَّجۡمُ ٱلثَّاقِبُ","turkishTransliteration":null,"turkishTranslation":"O, (ışığıyla karanlığı) delen yıldızdır"},{"number":4,"arabicText":"إِن كُلُّ نَفۡسٖ لَّمَّا عَلَيۡهَا حَافِظٞ","turkishTransliteration":null,"turkishTranslation":"Üzerinde gözetici olmayan kimse yoktur"},{"number":5,"arabicText":"فَلۡيَنظُرِ ٱلۡإِنسَٰنُ مِمَّ خُلِقَ","turkishTransliteration":null,"turkishTranslation":"Öyleyse insan neden yaratıldığına bir baksın"},{"number":6,"arabicText":"خُلِقَ مِن مَّآءٖ دَافِقٖ","turkishTransliteration":null,"turkishTranslation":"O, erkek ve kadının beli ile kaburga kemikleri arasından atılagelen bir sudan yaratılmıştır"},{"number":7,"arabicText":"يَخۡرُجُ مِنۢ بَيۡنِ ٱلصُّلۡبِ وَٱلتَّرَآئِبِ","turkishTransliteration":null,"turkishTranslation":"O, erkek ve kadının beli ile kaburga kemikleri arasından atılagelen bir sudan yaratılmıştır"},{"number":8,"arabicText":"إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ","turkishTransliteration":null,"turkishTranslation":"Şüphesiz Allah, gizliliklerin ortaya çıkacağı gün, insanı tekrar yaratmaya Kadir'dir"},{"number":9,"arabicText":"يَوۡمَ تُبۡلَى ٱلسَّرَآئِرُ","turkishTransliteration":null,"turkishTranslation":"Şüphesiz Allah, gizliliklerin ortaya çıkacağı gün, insanı tekrar yaratmaya Kadir'dir"},{"number":10,"arabicText":"فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖ","turkishTransliteration":null,"turkishTranslation":"O gün, insanın gücü de, yardımcısı da olmaz"},{"number":11,"arabicText":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجۡعِ","turkishTransliteration":null,"turkishTranslation":"Dönüşlü göğe ve yarılan yeryüzüne and olsun ki"},{"number":12,"arabicText":"وَٱلۡأَرۡضِ ذَاتِ ٱلصَّدۡعِ","turkishTransliteration":null,"turkishTranslation":"Dönüşlü göğe ve yarılan yeryüzüne and olsun ki"},{"number":13,"arabicText":"إِنَّهُۥ لَقَوۡلٞ فَصۡلٞ","turkishTransliteration":null,"turkishTranslation":"Doğrusu bu Kuran kesin bir sözdür"},{"number":14,"arabicText":"وَمَا هُوَ بِٱلۡهَزۡلِ","turkishTransliteration":null,"turkishTranslation":"O, eğlence için değildir"},{"number":15,"arabicText":"إِنَّهُمۡ يَكِيدُونَ كَيۡدٗا","turkishTransliteration":null,"turkishTranslation":"Gerçekten onlar düzen kuruyorlar"},{"number":16,"arabicText":"وَأَكِيدُ كَيۡدٗا","turkishTransliteration":null,"turkishTranslation":"Ben de bir düzen kurmaktayım"},{"number":17,"arabicText":"فَمَهِّلِ ٱلۡكَٰفِرِينَ أَمۡهِلۡهُمۡ رُوَيۡدَۢا","turkishTransliteration":null,"turkishTranslation":"Sen inkarcılara mehil ver; onlara mukabeleyi biraz geri bırak"}]}
