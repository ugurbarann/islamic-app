{"number":93,"nameTurkish":"Duhâ","nameArabic":"الضحى","revelationType":"Mekke","ayahCount":11,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"وَٱلضُّحَىٰ","turkishTransliteration":null,"turkishTranslation":"Kuşluk vaktine and olsun"},{"number":2,"arabicText":"وَٱلَّيۡلِ إِذَا سَجَىٰ","turkishTransliteration":null,"turkishTranslation":"Sükun erdiği zaman geceye and olsun ki"},{"number":3,"arabicText":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ","turkishTransliteration":null,"turkishTranslation":"Rabbin seni ne bıraktı ve ne de sana darıldı"},{"number":4,"arabicText":"وَلَلۡأٓخِرَةُ خَيۡرٞ لَّكَ مِنَ ٱلۡأُولَىٰ","turkishTransliteration":null,"turkishTranslation":"Doğrusu ahiret senin için dünyadan daha hayırlıdır"},{"number":5,"arabicText":"وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ فَتَرۡضَىٰٓ","turkishTransliteration":null,"turkishTranslation":"Rabbin şüphesiz sana verecek ve sen de hoşnut olacaksın"},{"number":6,"arabicText":"أَلَمۡ يَجِدۡكَ يَتِيمٗا فَـَٔاوَىٰ","turkishTransliteration":null,"turkishTranslation":"Seni öksüz bulup da barındırmadı mı"},{"number":7,"arabicText":"وَوَجَدَكَ ضَآلّٗا فَهَدَىٰ","turkishTransliteration":null,"turkishTranslation":"Seni şaşırmış bulup, doğru yola eriştirmedi mi"},{"number":8,"arabicText":"وَوَجَدَكَ عَآئِلٗا فَأَغۡنَىٰ","turkishTransliteration":null,"turkishTranslation":"Seni fakir bulup zenginleştirmedi mi"},{"number":9,"arabicText":"فَأَمَّا ٱلۡيَتِيمَ فَلَا تَقۡهَرۡ","turkishTransliteration":null,"turkishTranslation":"Öyleyse sakın öksüze kötü muamele etme"},{"number":10,"arabicText":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنۡهَرۡ","turkishTransliteration":null,"turkishTranslation":"Ve sakın bir şey isteyeni azarlama"},{"number":11,"arabicText":"وَأَمَّا بِنِعۡمَةِ رَبِّكَ فَحَدِّثۡ","turkishTransliteration":null,"turkishTranslation":"Yalnızca Rabbinin nimetini anlat"}]}
