{"number":94,"nameTurkish":"İnşirâh","nameArabic":"الشرح","revelationType":"Mekke","ayahCount":8,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ","turkishTransliteration":null,"turkishTranslation":"Senin gönlünü açmadık mı"},{"number":2,"arabicText":"وَوَضَعۡنَا عَنكَ وِزۡرَكَ","turkishTransliteration":null,"turkishTranslation":"Belini büken yükünü üzerinden almadık mı"},{"number":3,"arabicText":"ٱلَّذِيٓ أَنقَضَ ظَهۡرَكَ","turkishTransliteration":null,"turkishTranslation":"Belini büken yükünü üzerinden almadık mı"},{"number":4,"arabicText":"وَرَفَعۡنَا لَكَ ذِكۡرَكَ","turkishTransliteration":null,"turkishTranslation":"Senin şanını yükseltmedik mi"},{"number":5,"arabicText":"فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا","turkishTransliteration":null,"turkishTranslation":"Elbette güçlükle beraber şüphesiz bir kolaylık vardır"},{"number":6,"arabicText":"إِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرٗا","turkishTransliteration":null,"turkishTranslation":"Gerçekten, güçlükle beraber bir kolaylık vardır"},{"number":7,"arabicText":"فَإِذَا فَرَغۡتَ فَٱنصَبۡ","turkishTransliteration":null,"turkishTranslation":"Öyleyse, bir işi bitirince diğerine giriş"},{"number":8,"arabicText":"وَإِلَىٰ رَبِّكَ فَٱرۡغَب","turkishTransliteration":null,"turkishTranslation":"Ve ümit edeceğini yalnız Rabbinden iste"}]}
