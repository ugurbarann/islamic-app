{"number":55,"nameTurkish":"Rahmân","nameArabic":"الرحمن","revelationType":"Medine","ayahCount":78,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"ٱلرَّحۡمَٰنُ","turkishTransliteration":null,"turkishTranslation":"Rahman olan Allah Kuran'ı öğretti"},{"number":2,"arabicText":"عَلَّمَ ٱلۡقُرۡءَانَ","turkishTransliteration":null,"turkishTranslation":"Rahman olan Allah Kuran'ı öğretti"},{"number":3,"arabicText":"خَلَقَ ٱلۡإِنسَٰنَ","turkishTransliteration":null,"turkishTranslation":"İnsanı yarattı, ona konuşmayı öğretti"},{"number":4,"arabicText":"عَلَّمَهُ ٱلۡبَيَانَ","turkishTransliteration":null,"turkishTranslation":"İnsanı yarattı, ona konuşmayı öğretti"},{"number":5,"arabicText":"ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانٖ","turkishTransliteration":null,"turkishTranslation":"Güneş ve ayın hareketleri bir hesaba göredir"},{"number":6,"arabicText":"وَٱلنَّجۡمُ وَٱلشَّجَرُ يَسۡجُدَانِ","turkishTransliteration":null,"turkishTranslation":"Bitkiler ve ağaçlar O'nun buyruğuna boyun eğerler"},{"number":7,"arabicText":"وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلۡمِيزَانَ","turkishTransliteration":null,"turkishTranslation":"O, göğü yükseltmiştir; tartıyı koymuştur"},{"number":8,"arabicText":"أَلَّا تَطۡغَوۡاْ فِي ٱلۡمِيزَانِ","turkishTransliteration":null,"turkishTranslation":"Artık tartıda tecavüz etmeyin"},{"number":9,"arabicText":"وَأَقِيمُواْ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ وَلَا تُخۡسِرُواْ ٱلۡمِيزَانَ","turkishTransliteration":null,"turkishTranslation":"Tartmayı doğru yapın, tartıyı eksik tutmayın"},{"number":10,"arabicText":"وَٱلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ","turkishTransliteration":null,"turkishTranslation":"Allah, yeri yaratıkları için meydana getirmiştir"},{"number":11,"arabicText":"فِيهَا فَٰكِهَةٞ وَٱلنَّخۡلُ ذَاتُ ٱلۡأَكۡمَامِ","turkishTransliteration":null,"turkishTranslation":"Orada meyveler, salkımlı hurma ağaçları, kabuklu taneler, güzel kokulu otlar vardır"},{"number":12,"arabicText":"وَٱلۡحَبُّ ذُو ٱلۡعَصۡفِ وَٱلرَّيۡحَانُ","turkishTransliteration":null,"turkishTranslation":"Orada meyveler, salkımlı hurma ağaçları, kabuklu taneler, güzel kokulu otlar vardır"},{"number":13,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Ey insanlar ve cinler! Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":14,"arabicText":"خَلَقَ ٱلۡإِنسَٰنَ مِن صَلۡصَٰلٖ كَٱلۡفَخَّارِ","turkishTransliteration":null,"turkishTranslation":"O, insanı pişmiş çamur gibi kuru balçıktan yaratmıştır"},{"number":15,"arabicText":"وَخَلَقَ ٱلۡجَآنَّ مِن مَّارِجٖ مِّن نَّارٖ","turkishTransliteration":null,"turkishTranslation":"Cinleri de yalın bir alevden yaratmıştır"},{"number":16,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken; Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":17,"arabicText":"رَبُّ ٱلۡمَشۡرِقَيۡنِ وَرَبُّ ٱلۡمَغۡرِبَيۡنِ","turkishTransliteration":null,"turkishTranslation":"O, iki doğunun Rabbidir, iki batının Rabbidir"},{"number":18,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":19,"arabicText":"مَرَجَ ٱلۡبَحۡرَيۡنِ يَلۡتَقِيَانِ","turkishTransliteration":null,"turkishTranslation":"Acı ve tatlı sulu iki denizi birbirine kavuşmamak üzere salıvermiştir"},{"number":20,"arabicText":"بَيۡنَهُمَا بَرۡزَخٞ لَّا يَبۡغِيَانِ","turkishTransliteration":null,"turkishTranslation":"Aralarında bir engel vardır; birbirinin sınırını aşamazlar"},{"number":21,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":22,"arabicText":"يَخۡرُجُ مِنۡهُمَا ٱللُّؤۡلُؤُ وَٱلۡمَرۡجَانُ","turkishTransliteration":null,"turkishTranslation":"Bu iki denizden de inci ve mercan çıkar"},{"number":23,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":24,"arabicText":"وَلَهُ ٱلۡجَوَارِ ٱلۡمُنشَـَٔاتُ فِي ٱلۡبَحۡرِ كَٱلۡأَعۡلَٰمِ","turkishTransliteration":null,"turkishTranslation":"Denizde yürüyen dağlar gibi gemiler O'nundur"},{"number":25,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":26,"arabicText":"كُلُّ مَنۡ عَلَيۡهَا فَانٖ","turkishTransliteration":null,"turkishTranslation":"Yeryüzünde bulunan her şey fanidir"},{"number":27,"arabicText":"وَيَبۡقَىٰ وَجۡهُ رَبِّكَ ذُو ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ","turkishTransliteration":null,"turkishTranslation":"Ancak, yüce ve cömert olan Rabbinin varlığı bakidir"},{"number":28,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":29,"arabicText":"يَسۡـَٔلُهُۥ مَن فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ كُلَّ يَوۡمٍ هُوَ فِي شَأۡنٖ","turkishTransliteration":null,"turkishTranslation":"Göklerde ve yerde olan kimseler her şeyi O'ndan isterler; O her an kainata tasarruf etmektedir"},{"number":30,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":31,"arabicText":"سَنَفۡرُغُ لَكُمۡ أَيُّهَ ٱلثَّقَلَانِ","turkishTransliteration":null,"turkishTranslation":"Ey insan ve cin toplulukları! Sizin de hesabınızı ele alacağız"},{"number":32,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":33,"arabicText":"يَٰمَعۡشَرَ ٱلۡجِنِّ وَٱلۡإِنسِ إِنِ ٱسۡتَطَعۡتُمۡ أَن تَنفُذُواْ مِنۡ أَقۡطَارِ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ فَٱنفُذُواْۚ لَا تَنفُذُونَ إِلَّا بِسُلۡطَٰنٖ","turkishTransliteration":null,"turkishTranslation":"Ey cin ve insan toplulukları! Göklerin ve yerin çevresini aşıp geçmeye gücünüz yetiyorsa geçin! Ama Allah'ın verdiği bir güç olmaksızın geçemezsiniz ki"},{"number":34,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":35,"arabicText":"يُرۡسَلُ عَلَيۡكُمَا شُوَاظٞ مِّن نَّارٖ وَنُحَاسٞ فَلَا تَنتَصِرَانِ","turkishTransliteration":null,"turkishTranslation":"Ey insanlar ve cinler! Üzerinize dumansız bir alev ve ateşsiz bir duman gönderilir de kurtulamazsınız"},{"number":36,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":37,"arabicText":"فَإِذَا ٱنشَقَّتِ ٱلسَّمَآءُ فَكَانَتۡ وَرۡدَةٗ كَٱلدِّهَانِ","turkishTransliteration":null,"turkishTranslation":"Gök yarılıp da, gül gibi kızardığı, yağ gibi eridiği zaman haliniz nice olur"},{"number":38,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":39,"arabicText":"فَيَوۡمَئِذٖ لَّا يُسۡـَٔلُ عَن ذَنۢبِهِۦٓ إِنسٞ وَلَا جَآنّٞ","turkishTransliteration":null,"turkishTranslation":"O gün ne insana ve ne cine suçu sorulur"},{"number":40,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":41,"arabicText":"يُعۡرَفُ ٱلۡمُجۡرِمُونَ بِسِيمَٰهُمۡ فَيُؤۡخَذُ بِٱلنَّوَٰصِي وَٱلۡأَقۡدَامِ","turkishTransliteration":null,"turkishTranslation":"Suçlular simalarından tanınırlar da, alın saçlarından ve ayaklarından yakalanırlar"},{"number":42,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":43,"arabicText":"هَٰذِهِۦ جَهَنَّمُ ٱلَّتِي يُكَذِّبُ بِهَا ٱلۡمُجۡرِمُونَ","turkishTransliteration":null,"turkishTranslation":"İşte suçluların yalanladıkları cehennem budur"},{"number":44,"arabicText":"يَطُوفُونَ بَيۡنَهَا وَبَيۡنَ حَمِيمٍ ءَانٖ","turkishTransliteration":null,"turkishTranslation":"Onlar, cehennem ateşiyle kaynar su arasında dolaşır dururlar"},{"number":45,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":46,"arabicText":"وَلِمَنۡ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ","turkishTransliteration":null,"turkishTranslation":"Rabbine karşı durmaktan korkan kimseye iki cennet vardır"},{"number":47,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":48,"arabicText":"ذَوَاتَآ أَفۡنَانٖ","turkishTransliteration":null,"turkishTranslation":"Bu iki cennet türlü ağaçlarla doludur"},{"number":49,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":50,"arabicText":"فِيهِمَا عَيۡنَانِ تَجۡرِيَانِ","turkishTransliteration":null,"turkishTranslation":"Bu cennetlerden akan iki kaynak vardır"},{"number":51,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":52,"arabicText":"فِيهِمَا مِن كُلِّ فَٰكِهَةٖ زَوۡجَانِ","turkishTransliteration":null,"turkishTranslation":"Bu cennetlerde türlü meyveden çift çift vardır"},{"number":53,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":54,"arabicText":"مُتَّكِـِٔينَ عَلَىٰ فُرُشِۭ بَطَآئِنُهَا مِنۡ إِسۡتَبۡرَقٖۚ وَجَنَى ٱلۡجَنَّتَيۡنِ دَانٖ","turkishTransliteration":null,"turkishTranslation":"Orada, örtüleri parlak atlastan yataklara yaslanırlar; iki cennetin meyvelerini de kolayca toplarlar"},{"number":55,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":56,"arabicText":"فِيهِنَّ قَٰصِرَٰتُ ٱلطَّرۡفِ لَمۡ يَطۡمِثۡهُنَّ إِنسٞ قَبۡلَهُمۡ وَلَا جَآنّٞ","turkishTransliteration":null,"turkishTranslation":"Orada, bakışlarını yalnız eşlerine çevirmiş, daha önce ne insan ve ne de cinlerin dokunmuş olduğu eşler vardır"},{"number":57,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":58,"arabicText":"كَأَنَّهُنَّ ٱلۡيَاقُوتُ وَٱلۡمَرۡجَانُ","turkishTransliteration":null,"turkishTranslation":"Onlar yakut ve mercan gibidirler"},{"number":59,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":60,"arabicText":"هَلۡ جَزَآءُ ٱلۡإِحۡسَٰنِ إِلَّا ٱلۡإِحۡسَٰنُ","turkishTransliteration":null,"turkishTranslation":"İyiliğin karşılığı ancak iyilik değil midir"},{"number":61,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":62,"arabicText":"وَمِن دُونِهِمَا جَنَّتَانِ","turkishTransliteration":null,"turkishTranslation":"Bu iki cennetten başka iki cennet daha vardır"},{"number":63,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":64,"arabicText":"مُدۡهَآمَّتَانِ","turkishTransliteration":null,"turkishTranslation":"Renkleri koyu yeşildir"},{"number":65,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":66,"arabicText":"فِيهِمَا عَيۡنَانِ نَضَّاخَتَانِ","turkishTransliteration":null,"turkishTranslation":"İkisinde de durmadan fışkıran iki kaynak vardır"},{"number":67,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":68,"arabicText":"فِيهِمَا فَٰكِهَةٞ وَنَخۡلٞ وَرُمَّانٞ","turkishTransliteration":null,"turkishTranslation":"İkisinde de türlü türlü meyveler, hurmalıklar ve nar ağaçları vardır"},{"number":69,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":70,"arabicText":"فِيهِنَّ خَيۡرَٰتٌ حِسَانٞ","turkishTransliteration":null,"turkishTranslation":"Oralarda iyi huylu güzel kadınlar vardır"},{"number":71,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":72,"arabicText":"حُورٞ مَّقۡصُورَٰتٞ فِي ٱلۡخِيَامِ","turkishTransliteration":null,"turkishTranslation":"Çadırlar içinde ceylan gözlüler vardır"},{"number":73,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":74,"arabicText":"لَمۡ يَطۡمِثۡهُنَّ إِنسٞ قَبۡلَهُمۡ وَلَا جَآنّٞ","turkishTransliteration":null,"turkishTranslation":"Onlara daha önce insan da, cin de dokunmamıştır"},{"number":75,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":76,"arabicText":"مُتَّكِـِٔينَ عَلَىٰ رَفۡرَفٍ خُضۡرٖ وَعَبۡقَرِيٍّ حِسَانٖ","turkishTransliteration":null,"turkishTranslation":"Cennetlikler orada yeşil yastıklara ve harikulade işlemeli döşeklere yaslanırlar"},{"number":77,"arabicText":"فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ","turkishTransliteration":null,"turkishTranslation":"Öyleyken, Rabbinizin nimetlerinden hangisini yalanlarsınız"},{"number":78,"arabicText":"تَبَٰرَكَ ٱسۡمُ رَبِّكَ ذِي ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ","turkishTransliteration":null,"turkishTranslation":"Büyük ve pek cömert olan Rabbinin adı ne yücedir"}]}
