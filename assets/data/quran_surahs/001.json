{"number":1,"nameTurkish":"Fâtiha","nameArabic":"الفاتحة","revelationType":"Mekke","ayahCount":7,"source":"quran-json@3.1.2 chapters/tr (CC BY-SA 4.0)","ayahs":[{"number":1,"arabicText":"بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ","turkishTransliteration":null,"turkishTranslation":"Rahman ve Rahim olan Allah'ın adıyla"},{"number":2,"arabicText":"ٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَٰلَمِينَ","turkishTransliteration":null,"turkishTranslation":"Hamd, Alemlerin Rabbi Allah'a mahsustur"},{"number":3,"arabicText":"ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ","turkishTransliteration":null,"turkishTranslation":"O Rahman ve Rahim'dir"},{"number":4,"arabicText":"مَٰلِكِ يَوۡمِ ٱلدِّينِ","turkishTransliteration":null,"turkishTranslation":"Din Gününün sahibidir"},{"number":5,"arabicText":"إِيَّاكَ نَعۡبُدُ وَإِيَّاكَ نَسۡتَعِينُ","turkishTransliteration":null,"turkishTranslation":"Ancak Sana kulluk eder ve yalnız Senden yardım dileriz"},{"number":6,"arabicText":"ٱهۡدِنَا ٱلصِّرَٰطَ ٱلۡمُسۡتَقِيمَ","turkishTransliteration":null,"turkishTranslation":"Bizi doğru yola eriştir"},{"number":7,"arabicText":"صِرَٰطَ ٱلَّذِينَ أَنۡعَمۡتَ عَلَيۡهِمۡ غَيۡرِ ٱلۡمَغۡضُوبِ عَلَيۡهِمۡ وَلَا ٱلضَّآلِّينَ","turkishTransliteration":null,"turkishTranslation":"Nimete erdirdiğin kimselerin yoluna; gazaba uğrayanların, ya da sapıtanların yoluna değil"}]}
